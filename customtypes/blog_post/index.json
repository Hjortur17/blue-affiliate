{
  "format": "page",
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Post title"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description / Excerpt",
          "placeholder": "Short summary of the post"
        }
      },
      "featured_image": {
        "type": "Image",
        "config": {
          "label": "Featured Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "customtypes": ["blog_category"],
          "placeholder": "Select a category"
        }
      },
      "read_time": {
        "type": "Number",
        "config": {
          "label": "Read Time (minutes)",
          "placeholder": "e.g. 8"
        }
      },
      "published_date": {
        "type": "Date",
        "config": {
          "label": "Published Date"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "placeholder": "Full blog content",
          "allowTargetBlank": true,
          "multi": "paragraph,heading2,heading3,heading4,strong,em,hyperlink,image,embed,list-item,o-list-item,preformatted"
        }
      }
    }
  }
}
